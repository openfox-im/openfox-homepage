{
  "name": "openfox-homepage",
  "private": true,
  "version": "0.1.0",
  "description": "Static homepage for openfox.im, deployable to Cloudflare Workers or Pages.",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "cf:login": "wrangler login",
    "dev": "wrangler dev --assets public",
    "deploy": "wrangler deploy --assets public",
    "deploy:dry": "wrangler deploy --assets public --dry-run",
    "pages:create": "wrangler pages project create openfox-im",
    "deploy:pages": "wrangler pages deploy public --project-name openfox-im",
    "preview:pages": "wrangler pages dev public"
  },
  "devDependencies": {
    "three": "0.163.0",
    "wrangler": "^4.71.0"
  }
}
