{
  "name": "openfox-homepage",
  "private": true,
  "version": "0.1.0",
  "description": "Static homepage for openfox.im, deployed to Cloudflare Pages.",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "cf:login": "wrangler login",
    "dev": "wrangler pages dev public",
    "deploy": "wrangler pages deploy public --project-name openfox-homepage",
    "pages:create": "wrangler pages project create openfox-homepage",
    "preview:pages": "wrangler pages dev public",
    "verify:url": "node scripts/verify-deployment.mjs"
  },
  "devDependencies": {
    "three": "0.163.0",
    "wrangler": "^4.71.0"
  }
}
